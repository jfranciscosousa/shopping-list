{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "rangeStrategy": "bump",
  "schedule": ["* 0-3 * * *"],
  "automerge": true,
  "automergeType": "pr",
  "automergeSchedule": "at any time",
  "prConcurrentLimit": 0,
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "pinDigests": false
    }
  ]
}
